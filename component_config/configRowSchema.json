{
  "type": "object",
  "title": "Row Configuration",
  "properties": {

    "sync_options": {
      "type": "object",
      "title": "Sync Options",
      "propertyOrder": 100,
      "properties": {
        "workspace_id": {
          "type": "string",
          "title": "Workspace",
          "format": "select",
          "options": {
            "async": {
              "label": "LOAD WORKSPACES",
              "action": "list_workspaces"
            }
          },
          "enum": []
        },
        "board_id": {
          "type": "string",
          "title": "Board",
          "format": "select",
          "options": {
            "async": {
              "label": "LOAD BOARDS",
              "action": "list_boards",
              "autoload": ["parameters.sync_options.workspace_id"]
            }
          },
          "enum": []
        },
        "group_id": {
          "type": "string",
          "title": "Group",
          "format": "select",
          "options": {
            "async": {
              "label": "LOAD GROUPS",
              "action": "list_groups",
              "autoload": ["parameters.sync_options.board_id"]
            }
          },
          "enum": []
        },

        "batch_size": {
          "type": "integer",
          "title": "Batch Size",
          "default": 50
        },

        "load_monday_columns_button": {
          "type": "button",
          "format": "sync-action",
          "title": "Load Monday Columns",
          "options": {
            "async": {
              "label": "LOAD MONDAY COLUMNS",
              "action": "list_monday_columns",
              "cache": true
            }
          }
        }
      }
    },

    "unique_key": {
      "type": "object",
      "title": "Unique Field(s)",
      "propertyOrder": 200,
      "properties": {
        "source_column": {
          "type": "string",
          "title": "Unique Source Column",
          "format": "select",
          "options": {
            "async": {
              "label": "LOAD SOURCE COLUMNS",
              "action": "list_source_columns",
              "cache": true
            }
          }
        }
      }
    },

    "generate_mappings_button": {
      "type": "button",
      "format": "sync-action",
      "title": "Generate Field Mappings",
      "propertyOrder": 250,
      "options": {
        "async": {
          "label": "GENERATE FIELD MAPPINGS",
          "action": "generate_field_mappings",
          "cache": false
        }
      }
    },

    "field_mappings": {
      "type": "array",
      "title": "Column Mappings",
      "propertyOrder": 300,
      "format": "table",
      "items": {
        "type": "object",
        "properties": {
          "source_column": {
            "type": "string",
            "title": "Source Column",
            "format": "select",
            "options": {
              "async": {
                "label": "LOAD SOURCE COLUMNS",
                "action": "list_source_columns",
                "cache": true
              }
            }
          },
          "monday_column_id": {
            "type": "string",
            "title": "Monday Column",
            "format": "select",
            "options": {
              "async": {
                "label": "LOAD MONDAY COLUMNS",
                "action": "list_monday_columns",
                "autoload": ["parameters.sync_options.board_id"],
                "cache": true
              }
            }
          }
        }
      }
    }
  }
}
