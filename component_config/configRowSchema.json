{
  "type": "object",
  "title": "Row Configuration",
  "required": ["sync_options", "unique_key", "field_mappings"],
  "properties": {
    "sync_options": {
      "type": "object",
      "title": "Sync Options",
      "required": ["workspace_id", "board_id"],
      "properties": {
        "workspace_id": {
          "type": "string",
          "title": "Workspace",
          "format": "select",
          "description": "Select the Monday.com workspace.",
          "propertyOrder": 1,
          "options": {
            "async": {
              "label": "LOAD WORKSPACES",
              "action": "list_workspaces",
              "autoload": []
            }
          },
          "enum": []
        },
        "board_id": {
          "type": "string",
          "title": "Board",
          "format": "select",
          "description": "Select a Monday.com board within the chosen workspace.",
          "propertyOrder": 2,
          "options": {
            "async": {
              "label": "LOAD BOARDS",
              "action": "list_boards",
              "autoload": ["parameters.sync_options.workspace_id"]
            }
          },
          "enum": []
        },
        "group_id": {
          "type": "string",
          "title": "Group",
          "format": "select",
          "description": "Select a group within the selected board.",
          "propertyOrder": 3,
          "options": {
            "async": {
              "label": "LOAD GROUPS",
              "action": "list_groups",
              "autoload": ["parameters.sync_options.board_id"]
            }
          },
          "enum": []
        },
        "batch_size": {
          "type": "integer",
          "title": "Batch Size",
          "minimum": 1,
          "maximum": 500,
          "default": 50,
          "propertyOrder": 4
        }
      },
      "propertyOrder": 100
    },

    "unique_key": {
      "type": "object",
      "title": "Upsert Identity",
      "required": ["source_column", "monday_column_id"],
      "properties": {
        "source_column": {
          "type": "string",
          "title": "Unique Source Column",
          "description": "CSV column containing the business key.",
          "options": {
            "inputAttributes": { "placeholder": "e.g. Request Number" },
            "grid_columns": 2
          },
          "propertyOrder": 1
        },
        "monday_column_id": {
          "type": "string",
          "title": "Unique Monday Column",
          "description": "Use '__item_name__' to match by item name, or select a Monday column.",
          "format": "select",
          "enum": [],
          "default": "__item_name__",
          "options": {
            "allowCustom": true,
            "dependencies": {
              "sync_options.board_id": {
                "syncAction": "fetch_monday_columns"
              }
            },
            "inputAttributes": {
              "placeholder": "__item_name__ or choose from dropdown"
            },
            "grid_columns": 2
          },
          "propertyOrder": 2
        }
      },
      "propertyOrder": 200
    },

    "field_mappings": {
      "type": "array",
      "title": "Column Mappings",
      "description": "Map CSV columns to Monday.com columns.",
      "minItems": 0,
      "format": "table",
      "items": {
        "type": "object",
        "title": "Field Mapping",
        "required": ["source_column", "monday_column_id"],
        "properties": {
          "source_column": {
            "type": "string",
            "title": "Source Column",
            "propertyOrder": 1
          },
          "monday_column_id": {
            "type": "string",
            "title": "Monday Column",
            "format": "select",
            "enum": [],
            "options": {
              "allowCustom": true,
              "dependencies": {
                "sync_options.board_id": {
                  "syncAction": "fetch_monday_columns"
                }
              }
            },
            "propertyOrder": 2
          }
        }
      },
      "propertyOrder": 300
    }
  }
}
