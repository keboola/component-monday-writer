{
  "type": "object",
  "title": "Row Configuration",
  "required": [],
  "properties": {

    "sync_options": {
      "type": "object",
      "title": "Sync Options",
      "propertyOrder": 100,
      "properties": {
        "workspace_id": {
          "type": "string",
          "format": "select",
          "title": "Workspace",
          "options": {
            "async": {
              "label": "LOAD WORKSPACES",
              "action": "list_workspaces"
            }
          }
        },
        "board_id": {
          "type": "string",
          "format": "select",
          "title": "Board",
          "options": {
            "async": {
              "label": "LOAD BOARDS",
              "action": "list_boards",
              "autoload": ["parameters.sync_options.workspace_id"]
            }
          }
        },
        "group_id": {
          "type": "string",
          "format": "select",
          "title": "Group",
          "options": {
            "async": {
              "label": "LOAD GROUPS",
              "action": "list_groups",
              "autoload": ["parameters.sync_options.board_id"]
            }
          }
        },
        "batch_size": {
          "type": "integer",
          "title": "Batch Size",
          "default": 50
        }
      }
    },

    "load_monday_columns_button": {
      "type": "button",
      "format": "sync-action",
      "title": "Load Monday Columns",
      "propertyOrder": 150,
      "options": {
        "async": {
          "label": "LOAD MONDAY COLUMNS",
          "action": "list_monday_columns",
          "cache": false
        }
      }
    },

    "load_source_columns_button": {
      "type": "button",
      "format": "sync-action",
      "title": "Load Source Columns",
      "propertyOrder": 160,
      "options": {
        "async": {
          "label": "LOAD SOURCE COLUMNS",
          "action": "list_source_columns",
          "cache": false
        }
      }
    },

    "unique_key": {
      "type": "object",
      "title": "Unique Field(s)",
      "propertyOrder": 200,
      "properties": {
        "source_column": {
          "type": "string",
          "title": "Unique Source Column",
          "format": "select",
          "enumSource": "source_columns"
        }
      }
    },

    "generate_field_mappings_button": {
      "type": "button",
      "format": "sync-action",
      "title": "Generate Field Mappings",
      "propertyOrder": 250,
      "options": {
        "async": {
          "label": "GENERATE FIELD MAPPINGS",
          "action": "generate_field_mappings",
          "cache": false
        }
      }
    },

    "field_mappings": {
      "type": "array",
      "title": "Column Mappings",
      "propertyOrder": 300,
      "format": "table",
      "items": {
        "type": "object",
        "properties": {
          "source_column": {
            "type": "string",
            "format": "select",
            "title": "Source Column",
            "enumSource": "source_columns"
          },
          "monday_column_id": {
            "type": "string",
            "format": "select",
            "title": "Monday Column",
            "enumSource": "monday_columns"
          }
        }
      }
    }
  }
}
