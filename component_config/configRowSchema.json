{
  "type": "object",
  "title": "Row Configuration",
  "required": [],
  "properties": {
    "sync_options": {
      "type": "object",
      "title": "Sync Options",
      "propertyOrder": 100,
      "properties": {
        "workspace_id": {
          "type": "string",
          "title": "Workspace",
          "format": "select",
          "options": {
            "async": {
              "label": "LOAD WORKSPACES",
              "action": "list_workspaces"
            }
          },
          "enum": []
        },
        "board_id": {
          "type": "string",
          "title": "Board",
          "format": "select",
          "options": {
            "async": {
              "label": "LOAD BOARDS",
              "action": "list_boards",
              "autoload": ["parameters.sync_options.workspace_id"]
            }
          },
          "enum": []
        },
        "group_id": {
          "type": "string",
          "title": "Group",
          "format": "select",
          "options": {
            "async": {
              "label": "LOAD GROUPS",
              "action": "list_groups",
              "autoload": ["parameters.sync_options.board_id"]
            }
          },
          "enum": []
        },
        "batch_size": {
          "type": "integer",
          "title": "Batch Size",
          "default": 50,
          "minimum": 1,
          "maximum": 500
        }
      }
    },

    "load_metadata_button": {
      "type": "button",
      "format": "sync-action",
      "title": "Load Columns & Metadata",
      "description": "Loads source table columns, Monday.com columns, and generates field mappings.",
      "propertyOrder": 150,
      "options": {
        "async": {
          "label": "LOAD METADATA",
          "action": "load_all_metadata",
          "cache": false
        }
      }
    },

    "unique_key": {
      "type": "object",
      "title": "Unique Field(s)",
      "propertyOrder": 200,
      "properties": {
        "source_column": {
          "type": "string",
          "title": "Unique Source Column",
          "format": "select",
          "enumSource": "parameters._metadata_.source_columns"
        }
      }
    },

    "field_mappings": {
      "type": "array",
      "title": "Column Mappings",
      "propertyOrder": 300,
      "format": "table",
      "items": {
        "type": "object",
        "title": "Field Mapping",
        "required": ["source_column", "monday_column_id"],
        "properties": {
          "source_column": {
            "type": "string",
            "title": "Source Column",
            "enumSource": "parameters._metadata_.source_columns",
            "propertyOrder": 1
          },
          "monday_column_id": {
            "type": "string",
            "title": "Monday Column",
            "format": "select",
            "enumSource": "parameters._metadata_.monday_columns",
            "propertyOrder": 2
          }
        }
      }
    },

    "_metadata_": {
      "type": "object",
      "options": {
        "hidden": true
      }
    }
  }
}
