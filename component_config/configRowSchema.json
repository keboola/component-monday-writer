{
  "type": "object",
  "title": "Row Configuration",
  "required": ["sync_options", "unique_key", "field_mappings"],
  "properties": {
    "sync_options": {
      "type": "object",
      "title": "Sync Options",
      "required": ["board_id"],
      "properties": {
        "board_id": {
          "type": "string",
          "title": "Board ID",
          "description": "Monday.com board to write into (e.g. 9772074792).",
          "propertyOrder": 100
        },
        "group_id": {
          "type": "string",
          "title": "Group ID",
          "description": "Target group on the board. Leave empty to use the board default.",
          "default": "topics",
          "propertyOrder": 110
        },
        "batch_size": {
          "type": "integer",
          "title": "Batch Size",
          "description": "Process rows in chunks.",
          "minimum": 1,
          "maximum": 500,
          "default": 50,
          "propertyOrder": 120
        }
      },
      "propertyOrder": 100
    },

    "unique_key": {
      "type": "object",
      "title": "Upsert Identity",
      "description": "How to match existing items for update.",
      "required": ["source_column", "monday_column_id"],
      "properties": {
        "source_column": {
          "type": "string",
          "title": "Unique Source Column",
          "description": "CSV column containing the business key.",
          "options": {
            "inputAttributes": { "placeholder": "e.g. Request Number" },
            "grid_columns": 2
          },
          "propertyOrder": 1
        },
        "monday_column_id": {
          "type": "string",
          "title": "Unique Monday Column ID",
          "description": "Use '__item_name__' to match by item name, or enter a text column_id.",
          "default": "__item_name__",
          "pattern": "^(__item_name__|[A-Za-z0-9_]+)$",
          "options": {
            "inputAttributes": { "placeholder": "__item_name__ or e.g. text_abcd1234" },
            "grid_columns": 2
          },
          "propertyOrder": 2
        }
      },
      "propertyOrder": 200
    },

    "field_mappings": {
      "type": "array",
      "title": "Column Mappings",
      "description": "Map CSV columns to Monday column IDs. Use '__item_name__' to set the item name.",
      "minItems": 0,
      "format": "table",
      "items": {
        "type": "object",
        "title": "Field Mapping",
        "required": ["source_column", "monday_column_id"],
        "properties": {
          "source_column": {
            "type": "string",
            "title": "Source Column",
            "description": "CSV column name to read from.",
            "options": { "inputAttributes": { "placeholder": "e.g. Brand" } },
            "propertyOrder": 1
          },
          "monday_column_id": {
            "type": "string",
            "title": "Monday Column ID",
            "description": "Target column_id (free text). Use '__item_name__' to set the item name.",
            "pattern": "^(__item_name__|[A-Za-z0-9_]+)$",
            "options": {
              "inputAttributes": { "placeholder": "e.g. color_xxx, text_xxx, date_xxx, __item_name__" }
            },
            "propertyOrder": 2
          }
        }
      },
      "propertyOrder": 300
    }
  }
}
