{
  "type": "object",
  "title": "Row Configuration",
  "required": ["sync_options", "unique_key", "field_mappings"],
  "properties": {
    "sync_options": {
      "type": "object",
      "title": "Sync Options",
      "required": ["board_id"],
      "properties": {
        "load_boards_button": {
          "type": "button",
          "title": "Load Boards",
          "format": "sync-action",
          "propertyOrder": 1,
          "options": {
            "async": {
              "label": "LOAD BOARDS",
              "action": "list_boards",
              "cache": false
            }
          }
        },
        "board_id": {
          "type": "string",
          "title": "Board",
          "format": "select",
          "enum": [],
          "description": "Select a Monday.com board to write into.",
          "propertyOrder": 2
        },
        "load_groups_button": {
          "type": "button",
          "title": "Load Groups",
          "format": "sync-action",
          "propertyOrder": 3,
          "options": {
            "async": {
              "label": "LOAD GROUPS",
              "action": "list_groups",
              "autoload": ["parameters.sync_options.board_id"],
              "cache": false
            }
          }
        },
        "group_id": {
          "type": "string",
          "title": "Group",
          "format": "select",
          "enum": [],
          "description": "Select a group within the selected board.",
          "propertyOrder": 4
        },
        "batch_size": {
          "type": "integer",
          "title": "Batch Size",
          "description": "Process Monday.com board data in chunks (default 50, max 500).",
          "minimum": 1,
          "maximum": 500,
          "default": 50,
          "propertyOrder": 5
        }
      }
    },

    "unique_key": {
      "type": "object",
      "title": "Upsert Identity",
      "description": "How to match existing items for update.",
      "required": ["source_column", "monday_column_id"],
      "properties": {
        "source_column": {
          "type": "string",
          "title": "Unique Source Column",
          "description": "CSV column containing the business key.",
          "options": {
            "inputAttributes": { "placeholder": "e.g. Request Number" },
            "grid_columns": 2
          },
          "propertyOrder": 1
        },
        "monday_column_id": {
          "type": "string",
          "title": "Unique Monday Column",
          "description": "Use '__item_name__' to match by item name, or select a column from Monday.com.",
          "format": "select",
          "enum": [],
          "default": "__item_name__",
          "options": {
            "allowCustom": true,
            "dependencies": {
              "sync_options.board_id": {
                "syncAction": "fetch_monday_columns",
                "autoload": ["parameters.sync_options.board_id"]
              }
            },
            "inputAttributes": {
              "placeholder": "__item_name__ or choose from dropdown"
            },
            "grid_columns": 2
          },
          "propertyOrder": 2
        }
      },
      "propertyOrder": 200
    },

    "field_mappings": {
      "type": "array",
      "title": "Column Mappings",
      "description": "Map CSV columns to Monday.com columns. Use '__item_name__' to set the item name.",
      "minItems": 0,
      "format": "table",
      "items": {
        "type": "object",
        "title": "Field Mapping",
        "required": ["source_column", "monday_column_id"],
        "properties": {
          "source_column": {
            "type": "string",
            "title": "Source Column",
            "description": "CSV column name to read from.",
            "options": {
              "inputAttributes": { "placeholder": "e.g. Brand" }
            },
            "propertyOrder": 1
          },
          "monday_column_id": {
            "type": "string",
            "title": "Monday Column",
            "description": "Select a Monday.com column for this source field.",
            "format": "select",
            "enum": [],
            "options": {
              "allowCustom": true,
              "dependencies": {
                "sync_options.board_id": {
                  "syncAction": "fetch_monday_columns",
                  "autoload": ["parameters.sync_options.board_id"]
                }
              },
              "inputAttributes": {
                "placeholder": "e.g. Status, Due Date, Owner"
              }
            },
            "propertyOrder": 2
          }
        }
      },
      "propertyOrder": 300
    },

    "load_columns_button": {
      "type": "button",
      "format": "sync-action",
      "title": "Load Source Columns",
      "description": "Fetch columns from the selected input table and prefill Source Column options.",
      "options": {
        "async": {
          "cache": false,
          "label": "LOAD SOURCE COLUMNS",
          "action": "return_monday_table_types"
        }
      },
      "propertyOrder": 400
    }
  }
}
